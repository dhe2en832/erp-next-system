# ============================================================================
# ERPNext Multi-Site Configuration
# ============================================================================

# OPTION 1: Multi-Site Configuration (Recommended for multiple ERPNext instances)
# ----------------------------------------------------------------------------
# Configure multiple ERPNext sites as a JSON array
# Each site needs: name, displayName, apiUrl, apiKey, apiSecret
# Set isDefault: true for the default site

# Example for production sites:
# ERPNEXT_SITES='[{"name":"bac-production","displayName":"BAC Production","apiUrl":"https://bac.batasku.cloud","apiKey":"your_api_key","apiSecret":"your_api_secret","isDefault":true},{"name":"demo-site","displayName":"Demo Site","apiUrl":"https://demo.batasku.cloud","apiKey":"your_api_key","apiSecret":"your_api_secret"},{"name":"cirebon","displayName":"Cirebon","apiUrl":"https://cirebon.batasku.cloud","apiKey":"your_api_key","apiSecret":"your_api_secret"},{"name":"cv-cirebon","displayName":"CV Cirebon","apiUrl":"https://cvcirebon.batasku.cloud","apiKey":"your_api_key","apiSecret":"your_api_secret"}]'

# Example for local development:
# ERPNEXT_SITES='[{"name":"batasku-local","displayName":"Batasku Local","apiUrl":"http://batasku.local:8000","apiKey":"your_api_key","apiSecret":"your_api_secret","isDefault":true},{"name":"demo-local","displayName":"Demo Local","apiUrl":"http://demo.batasku.local:8000","apiKey":"your_api_key","apiSecret":"your_api_secret"}]'

# Specify default site (optional - uses first site or site with isDefault: true)
# ERPNEXT_DEFAULT_SITE=bac-production

# ============================================================================
# OPTION 2: Single-Site Configuration (Legacy - for backward compatibility)
# ============================================================================
# Use this format if you only have one ERPNext instance
# This will be automatically migrated to multi-site format

ERPNEXT_API_URL=http://localhost:8000
ERP_API_KEY=your_api_key_here
ERP_API_SECRET=your_api_secret_here

# ============================================================================
# Other Configuration
# ============================================================================

# Environment Identifier (development/staging/production)
NEXT_PUBLIC_APP_ENV=development

# ============================================================================
# Instructions
# ============================================================================
# 1. For development: Copy this file to .env.local
# 2. For staging: Copy this file to .env.staging.local (overrides .env.staging)
# 3. For production: Copy this file to .env.production.local (overrides .env.production)
# 4. Replace the values with your actual ERPNext credentials
# 5. Get API credentials from ERPNext: User Menu > API Access > Generate Keys
# 6. For multi-site: Use ERPNEXT_SITES (Option 1)
# 7. For single-site: Use ERPNEXT_API_URL, ERP_API_KEY, ERP_API_SECRET (Option 2)

# Environment Variable Hierarchy (Next.js loads in this order):
# 1. .env.production.local (production only, not committed)
# 2. .env.staging.local (staging only, not committed)
# 3. .env.local (all environments, not committed)
# 4. .env.production (production defaults, committed)
# 5. .env.staging (staging defaults, committed)
# 6. .env (base defaults, committed)

# Deployment Commands:
# - Development: pnpm dev
# - Build for staging: pnpm build:staging
# - Build for production: pnpm build:production
# - Start staging: pnpm start:staging
# - Start production: pnpm start:production
# - Rollback production: pnpm rollback:production
