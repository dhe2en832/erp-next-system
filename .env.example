# ERPNext API Configuration
ERPNEXT_API_URL=http://localhost:8000
ERP_API_KEY=your_api_key_here
ERP_API_SECRET=your_api_secret_here

# Environment Identifier (development/staging/production)
NEXT_PUBLIC_APP_ENV=development

# Instructions:
# 1. For development: Copy this file to .env.local
# 2. For staging: Copy this file to .env.staging.local (overrides .env.staging)
# 3. For production: Copy this file to .env.production.local (overrides .env.production)
# 4. Replace the values with your actual ERPNext credentials
# 5. Get API credentials from ERPNext: User Menu > API Access > Generate Keys

# Environment Variable Hierarchy (Next.js loads in this order):
# 1. .env.production.local (production only, not committed)
# 2. .env.staging.local (staging only, not committed)
# 3. .env.local (all environments, not committed)
# 4. .env.production (production defaults, committed)
# 5. .env.staging (staging defaults, committed)
# 6. .env (base defaults, committed)

# Deployment Commands:
# - Development: pnpm dev
# - Build for staging: pnpm build:staging
# - Build for production: pnpm build:production
# - Start staging: pnpm start:staging
# - Start production: pnpm start:production
# - Rollback production: pnpm rollback:production
